generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OFFICE_STAFF
  PILOT
  MEDIA_SELLER
  CUSTOM
  KIOSK
}

enum CustomerStatus {
  REGISTERED
  ASSIGNED
  IN_FLIGHT
  COMPLETED
  CANCELLED
}

enum FlightStatus {
  ASSIGNED
  PICKED_UP
  IN_FLIGHT
  COMPLETED
  CANCELLED
}

enum CancelReason {
  WEATHER
  CUSTOMER_CANCEL
  OTHER
}

enum SwapStatus {
  PENDING
  APPROVED
  DECLINED
  EXPIRED
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  TRANSFER
}

enum PilotStatus {
  AVAILABLE
  ASSIGNED
  PICKED_UP
  IN_FLIGHT
  ON_BREAK
  OFF_DUTY
  UNAVAILABLE
}

enum Currency {
  EUR
  USD
  GBP
  RUB
  TRY
}

enum MediaDeliveryStatus {
  PENDING
  PAID
  DELIVERED
}

model User {
  id                String             @id @default(uuid())
  username          String             @unique
  name              String?
  passwordHash      String             @map("password_hash")
  plainPassword     String?            @map("plain_password")
  role              UserRole
  isActive          Boolean            @default(true) @map("is_active")
  pilotId           String?            @unique @map("pilot_id")
  pilot             Pilot?             @relation(fields: [pilotId], references: [id])
  posCategories     Json?              @map("pos_categories")
  passwordChangedAt DateTime?          @map("password_changed_at")
  sales             Sale[]
  pushSubscriptions PushSubscription[]
  fcmTokens         FcmToken[]
  pilotPayments     PilotPayment[]
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([role])
  @@map("users")
}

model Pilot {
  id               String             @id @default(uuid())
  name             String
  phone            String
  email            String?
  dailyFlightCount Int                @default(0) @map("daily_flight_count")
  maxDailyFlights  Int                @default(7) @map("max_daily_flights")
  isActive         Boolean            @default(true) @map("is_active")
  inQueue          Boolean            @default(true) @map("in_queue")
  isInExcel        Boolean            @default(true) @map("is_in_excel")
  queuePosition    Int                @map("queue_position")
  status           PilotStatus        @default(AVAILABLE)
  appInstalled     Boolean            @default(false) @map("app_installed")
  // Feragat (forfeit) sistemi
  forfeitCount     Int                @default(0) @map("forfeit_count")
  lastForfeitRound Int?               @map("last_forfeit_round")
  lockedUntilRound Int?               @map("locked_until_round")
  // Takım
  teamId           String?            @map("team_id")
  team             Team?              @relation(fields: [teamId], references: [id])
  isTeamLeader     Boolean            @default(false) @map("is_team_leader")
  // Pilotaj ücreti (null ise global ayar kullanılır)
  flightFee        Decimal?           @db.Decimal(10, 2) @map("flight_fee")
  // Per-pilot TUR sayacı (uçtukça veya feragat ettikçe artar)
  roundCount       Int                @default(0) @map("round_count")
  // Firma bilgisi
  companyId        String?            @map("company_id")
  company          Company?           @relation(fields: [companyId], references: [id])
  payments         PilotPayment[]
  user             User?
  customers        Customer[]
  flights          Flight[]
  mediaFolders     MediaFolder[]
  requesterSwaps   PilotSwapRequest[] @relation("RequesterSwaps")
  targetSwaps      PilotSwapRequest[] @relation("TargetSwaps")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([status])
  @@index([dailyFlightCount])
  @@index([isActive, status, dailyFlightCount])
  @@index([teamId])
  @@map("pilots")
}

model Customer {
  id               String         @id @default(uuid())
  displayId        String         @unique @map("display_id")
  firstName        String         @map("first_name")
  lastName         String         @map("last_name")
  email            String?
  phone            String
  emergencyContact String?        @map("emergency_contact")
  weight           Float?
  qrCode           String?        @map("qr_code")
  waiverSigned     Boolean        @default(false) @map("waiver_signed")
  waiverSignedAt   DateTime?      @map("waiver_signed_at")
  signatureData    String?        @db.Text @map("signature_data")
  kvkkConsent      Boolean        @default(false) @map("kvkk_consent")
  kvkkConsentAt    DateTime?      @map("kvkk_consent_at")
  waiverPdfPath    String?        @map("waiver_pdf_path")
  mediaFolderPath  String?        @map("media_folder_path")
  language         String         @default("tr")
  assignedPilotId  String?        @map("assigned_pilot_id")
  assignedPilot    Pilot?         @relation(fields: [assignedPilotId], references: [id])
  status           CustomerStatus @default(REGISTERED)
  flights          Flight[]
  mediaFolders     MediaFolder[]
  sales            Sale[]
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@index([displayId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedPilotId])
  @@map("customers")
}

model Flight {
  id                      String        @id @default(uuid())
  customerId              String        @map("customer_id")
  customer                Customer      @relation(fields: [customerId], references: [id])
  pilotId                 String        @map("pilot_id")
  pilot                   Pilot         @relation(fields: [pilotId], references: [id])
  status                  FlightStatus  @default(ASSIGNED)
  assignedAt              DateTime      @default(now()) @map("assigned_at")
  pickupAt                DateTime?     @map("pickup_at")
  takeoffAt               DateTime?     @map("takeoff_at")
  landingAt               DateTime?     @map("landing_at")
  durationMinutes         Int?          @map("duration_minutes")
  notes                   String?
  // İptal detayları
  cancellationReason      CancelReason? @map("cancellation_reason")
  cancellationNote        String?       @map("cancellation_note")
  preserveQueuePosition   Boolean       @default(false) @map("preserve_queue_position")
  // Yeniden aktifleştirme
  reactivatedFromFlightId String?       @map("reactivated_from_flight_id")
  reactivatedFrom         Flight?       @relation("FlightReactivation", fields: [reactivatedFromFlightId], references: [id])
  reactivations           Flight[]      @relation("FlightReactivation")
  mediaFolder             MediaFolder?
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([pilotId])
  @@index([customerId])
  @@index([pilotId, status])
  @@index([createdAt])
  @@map("flights")
}

model MediaFolder {
  id              String              @id @default(uuid())
  flightId        String              @unique @map("flight_id")
  flight          Flight              @relation(fields: [flightId], references: [id])
  customerId      String              @map("customer_id")
  customer        Customer            @relation(fields: [customerId], references: [id])
  pilotId         String              @map("pilot_id")
  pilot           Pilot               @relation(fields: [pilotId], references: [id])
  folderPath      String              @map("folder_path")
  fileCount       Int                 @default(0) @map("file_count")
  totalSizeBytes  BigInt              @default(0) @map("total_size_bytes")
  paymentStatus   String              @default("PENDING") @map("payment_status")
  deliveryStatus  String              @default("PENDING") @map("delivery_status")
  paymentAmount   Float?              @map("payment_amount")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([pilotId])
  @@index([paymentStatus])
  @@index([deliveryStatus])
  @@map("media_folders")
}

model Sale {
  id              String          @id @default(uuid())
  customerId      String?         @map("customer_id")
  customer        Customer?       @relation(fields: [customerId], references: [id])
  itemType        String          @map("item_type")
  itemName        String          @map("item_name")
  quantity        Int             @default(1)
  unitPrice       Float           @map("unit_price")
  totalPrice      Float           @map("total_price")
  totalAmountEUR  Float?          @map("total_amount_eur")
  totalAmountTRY  Float?          @map("total_amount_try")
  primaryCurrency Currency        @default(TRY) @map("primary_currency")
  isSplitPayment  Boolean         @default(false) @map("is_split_payment")
  paymentStatus   PaymentStatus   @default(UNPAID)
  paymentMethod   PaymentMethod?  @map("payment_method")
  soldById        String          @map("sold_by_id")
  soldBy          User            @relation(fields: [soldById], references: [id])
  paymentDetails  PaymentDetail[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("sales")
}

model Product {
  id            String   @id @default(uuid())
  name          String
  category      String
  price         Float
  priceCurrency Currency @default(EUR) @map("price_currency")
  isActive      Boolean  @default(true) @map("is_active")
  isFavorite    Boolean  @default(false) @map("is_favorite")
  stock         Int?
  lowStockAlert Int?     @map("low_stock_alert")
  imageUrl      String?  @map("image_url")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isActive])
  @@index([isFavorite])
  @@map("products")
}

model ExchangeRate {
  id           String   @id @default(uuid())
  baseCurrency Currency @default(EUR) @map("base_currency")
  currency     Currency
  buyRate      Float    @map("buy_rate")
  sellRate     Float    @map("sell_rate")
  source       String   @default("TCMB")
  fetchedAt    DateTime @map("fetched_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([baseCurrency, currency])
  @@map("exchange_rates")
}

model ExchangeRateHistory {
  id           String   @id @default(uuid())
  baseCurrency Currency @default(EUR) @map("base_currency")
  currency     Currency
  buyRate      Float    @map("buy_rate")
  sellRate     Float    @map("sell_rate")
  source       String
  fetchedAt    DateTime @map("fetched_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([currency, fetchedAt])
  @@map("exchange_rate_history")
}

model PaymentDetail {
  id             String        @id @default(uuid())
  saleId         String        @map("sale_id")
  sale           Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  currency       Currency
  amount         Float
  amountInEUR    Float         @map("amount_in_eur")
  amountInTRY    Float         @map("amount_in_try")
  exchangeRate   Float         @map("exchange_rate")
  exchangeSource String        @map("exchange_source")
  paymentMethod  PaymentMethod @map("payment_method")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("payment_details")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  device    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([isActive])
  @@map("push_subscriptions")
}

model RolePermission {
  id          String   @id @default(uuid())
  role        UserRole @unique
  permissions Json     @default("{}")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("role_permissions")
}

model NotificationSetting {
  id        String   @id @default(uuid())
  settings  Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  device    String?
  platform  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([isActive])
  @@map("fcm_tokens")
}

model PilotNotification {
  id        String   @id @default(uuid())
  pilotId   String   @map("pilot_id")
  title     String
  body      String
  type      String   @default("general")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([pilotId, createdAt])
  @@map("pilot_notifications")
}

// Takım modeli — 8'li pilot grupları
model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#3b82f6")
  sortOrder Int      @default(0) @map("sort_order")
  pilots    Pilot[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

// Global kuyruk durumu — tek satırlık singleton
model QueueState {
  id                 String   @id @default("singleton")
  currentRound       Int      @default(0) @map("current_round")
  assignmentsInRound Int      @default(0) @map("assignments_in_round")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("queue_state")
}

// Global ayarlar (pilotaj ücreti vs.)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// Firma modeli — pilotun bağlı olduğu acente
model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#3b82f6")
  sortOrder Int      @default(0) @map("sort_order")
  pilots    Pilot[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// Pilot ödeme kayıtları — hakediş takibi için
model PilotPayment {
  id         String    @id @default(uuid())
  pilotId    String    @map("pilot_id")
  pilot      Pilot     @relation(fields: [pilotId], references: [id])
  amount     Decimal   @db.Decimal(10, 2)
  note       String?
  paidById   String    @map("paid_by_id")
  paidBy     User      @relation(fields: [paidById], references: [id])
  periodFrom DateTime? @map("period_from")
  periodTo   DateTime? @map("period_to")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  @@index([pilotId, createdAt])
  @@index([paidById])
  @@map("pilot_payments")
}

// Pilot Swap Request — müşteri transferi için onay sistemi
model PilotSwapRequest {
  id                String     @id @default(uuid())
  requesterPilotId  String     @map("requester_pilot_id")
  requester         Pilot      @relation("RequesterSwaps", fields: [requesterPilotId], references: [id])
  requesterFlightId String     @map("requester_flight_id")
  targetPilotId     String     @map("target_pilot_id")
  target            Pilot      @relation("TargetSwaps", fields: [targetPilotId], references: [id])
  targetFlightId    String     @map("target_flight_id")
  status            SwapStatus @default(PENDING)
  createdAt         DateTime   @default(now()) @map("created_at")
  respondedAt       DateTime?  @map("responded_at")
  expiresAt         DateTime   @map("expires_at")

  @@index([status])
  @@index([targetPilotId, status])
  @@index([requesterPilotId, status])
  @@map("pilot_swap_requests")
}
