# Database (with connection pool settings for 500+ daily customers)
DATABASE_URL=postgresql://skytrack:skytrack@localhost:5432/skytrack?connection_limit=50&pool_timeout=10

# Redis Cache
REDIS_URL=redis://localhost:6379

# Server Configuration
SERVER_IP=192.168.1.100
SERVER_PORT=3001

# Frontend Configuration
NEXT_PUBLIC_SERVER_IP=192.168.1.100
NEXT_PUBLIC_API_URL=http://192.168.1.100:3001/api

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Media Storage
MEDIA_STORAGE_PATH=./media

# Business Rules
MAX_DAILY_FLIGHTS=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
